digraph metadata_injector_architecture {
    rankdir=TB;
    node [shape=box, style=filled, fillcolor=lightblue];

    metadata_injector [label="MetadataInjector<TMetadata>\nGeneric Injector Template"];

    node [shape=box, style=filled, fillcolor=lightyellow];
    provision_interface [label="Provision Interface"];

    metadata_injector -> provision_interface [label="provides"];

    subgraph cluster_provision {
        label="Metadata Provision Methods";
        color=lightgrey;
        metadata_type [label="MetadataType = TMetadata\nType alias"];
        get_metadata [label="get_metadata() const noexcept\nConst access to metadata"];
        set_metadata [label="set_metadata(TMetadata)\nUpdate metadata value"];
        metadata_storage [label="TMetadata metadata_\nPrivate storage"];
    }

    provision_interface -> metadata_type;
    provision_interface -> get_metadata;
    provision_interface -> set_metadata;
    provision_interface -> metadata_storage;

    node [shape=box, style=filled, fillcolor=orange];
    injection_interface [label="Injection Interface"];

    metadata_injector -> injection_interface [label="provides"];

    subgraph cluster_injection {
        label="Envelope Injection Methods";
        color=lightgrey;
        inject_into_templated [label="inject_into<TEnvelope>(...)\nTemplated injection"];
        inject_into_convenience [label="inject_into<TEnvelope>()\nConvenience overload"];
        default_implementation [label="Default assign_metadata()\nEnvelope integration"];
    }

    injection_interface -> inject_into_templated;
    injection_interface -> inject_into_convenience;
    injection_interface -> default_implementation;

    node [shape=box, style=filled, fillcolor=lightgreen];
    inheritance_extensibility [label="Inheritance Extensibility"];

    metadata_injector -> inheritance_extensibility [label="supports"];

    subgraph cluster_extensibility {
        label="CRTP and Inheritance Support";
        color=lightgrey;
        protected_metadata [label="protected TMetadata metadata_\nSubclass access"];
        virtual_injection [label="virtual inject_into override\nSpecialized behavior"];
        template_specialization [label="Template specialization\nType-specific behavior"];
    }

    inheritance_extensibility -> protected_metadata;
    inheritance_extensibility -> virtual_injection;
    inheritance_extensibility -> template_specialization;

    node [shape=box, style=filled, fillcolor=purple];
    contract_compliance [label="Contract Compliance"];

    metadata_injector -> contract_compliance [label="satisfies"];

    subgraph cluster_contract {
        label="MetadataInjectorConcept Requirements";
        color=lightgrey;
        has_metadata_type [label="has_metadata_type<T>\n✓ Satisfied"];
        has_get_method [label="has_get_metadata_method<T>\n✓ Satisfied"];
        has_inject_method [label="has_inject_into_method<T>\n✓ Satisfied"];
        is_injector_contract [label="is_metadata_injector<T>\n✓ Satisfied"];
    }

    contract_compliance -> has_metadata_type;
    contract_compliance -> has_get_method;
    contract_compliance -> has_inject_method;
    contract_compliance -> is_injector_contract;

    node [shape=box, style=filled, fillcolor=pink];
    assembler_integration [label="Assembler Integration"];

    metadata_injector -> assembler_integration [label="enables"];

    subgraph cluster_integration {
        label="EnvelopeAssemblerBase Usage";
        color=lightgrey;
        template_parameter [label="TMetadataInjector parameter\nType-safe composition"];
        metadata_injection [label="inject_into(envelope)\nEnvelope preparation"];
        compile_validation [label="Contract validation\nCompile-time safety"];
    }

    assembler_integration -> template_parameter;
    assembler_integration -> metadata_injection;
    assembler_integration -> compile_validation;
}